<?xml version="1.0" encoding="UTF-8"?>
<!--
  LuaUI Light Theme
  
  颜色格式: #RRGGBB 或 #AARRGGBB
  浮点数格式: 数字 (如 12.0)
  Thickness 格式: "left,top,right,bottom" 或 "all"
  CornerRadius 格式: "topLeft,topRight,bottomRight,bottomLeft" 或 "all"
-->
<Theme Name="Light" IsDark="false">

  <!-- ============================================================ -->
  <!-- 全局通用                                                       -->
  <!-- ============================================================ -->
  <Color Key="AccentColor"         Value="#0078D7" />
  <Color Key="BackgroundPrimary"   Value="#FFFFFF" />
  <Color Key="BackgroundSecondary" Value="#F5F5F5" />
  <Color Key="TextPrimary"         Value="#000000" />
  <Color Key="TextSecondary"       Value="#666666" />
  <Color Key="TextDisabled"        Value="#999999" />
  <Color Key="BorderNormal"        Value="#CCCCCC" />
  <Color Key="BorderFocused"       Value="#0078D7" />
  <Color Key="FocusVisual"         Value="#0078D7" />

  <!-- ============================================================ -->
  <!-- Button                                                        -->
  <!-- ============================================================ -->
  <Color Key="ButtonNormalBg"       Value="#E0E0E0" />
  <Color Key="ButtonHoverBg"        Value="#C0C0C0" />
  <Color Key="ButtonPressedBg"      Value="#A0A0A0" />
  <Color Key="ButtonDisabledBg"     Value="#F5F5F5" />
  <Color Key="ButtonDisabledFg"     Value="#BDBDBD" />
  <Color Key="ButtonDisabledBorder" Value="#E0E0E0" />
  <Color Key="ButtonBorder"         Value="#808080" />
  <Color Key="ButtonForeground"     Value="#000000" />
  <Color Key="ButtonNormalBorder"   Value="#808080" />
  <Color Key="ButtonHoverBorder"    Value="#606060" />
  <Color Key="ButtonPressedBorder"  Value="#404040" />

  <!-- ============================================================ -->
  <!-- CheckBox / RadioButton                                        -->
  <!-- ============================================================ -->
  <Color Key="CheckNormalBorder"   Value="#808080" />
  <Color Key="CheckHoverBorder"    Value="#0078D7" />
  <Color Key="CheckPressedBorder"  Value="#005A9E" />
  <Color Key="CheckMark"           Value="#0078D7" />
  <Color Key="CheckBackground"     Value="#FFFFFF" />
  <Color Key="CheckDisabledBorder" Value="#BDBDBD" />
  <Color Key="CheckDisabledMark"   Value="#BDBDBD" />
  <Color Key="CheckDisabledText"   Value="#999999" />

  <!-- ============================================================ -->
  <!-- Slider                                                        -->
  <!-- ============================================================ -->
  <Color Key="SliderTrack"       Value="#E0E0E0" />
  <Color Key="SliderProgress"    Value="#0078D7" />
  <Color Key="SliderThumbBg"     Value="#FFFFFF" />
  <Color Key="SliderThumbBorder" Value="#0078D7" />
  <Color Key="SliderThumb"       Value="#0078D7" />

  <!-- ============================================================ -->
  <!-- TextBox                                                       -->
  <!-- ============================================================ -->
  <Color Key="TextBoxBackground"    Value="#FFFFFF" />
  <Color Key="TextBoxBorder"        Value="#808080" />
  <Color Key="TextBoxFocusedBorder" Value="#0078D7" />
  <Color Key="TextBoxSelection"     Value="#0078D7" />
  <Color Key="TextBoxInactiveSelection" Value="#D8D8D8" />
  <Color Key="TextBoxPlaceholder"   Value="#8A8A8A" />
  <Color Key="TextBoxReadOnlyBg"    Value="#F5F5F5" />

  <!-- ============================================================ -->
  <!-- ProgressBar                                                   -->
  <!-- ============================================================ -->
  <Color Key="ProgressBackground" Value="#E0E0E0" />
  <Color Key="ProgressForeground" Value="#0078D7" />
  <Color Key="ProgressBorder"     Value="#CCCCCC" />

  <!-- ============================================================ -->
  <!-- TabControl                                                    -->
  <!-- ============================================================ -->
  <Color Key="TabStripBg"    Value="#F5F5F5" />
  <Color Key="TabSelectedBg" Value="#FFFFFF" />
  <Color Key="TabHoverBg"    Value="#E8E8E8" />
  <Color Key="TabBorder"     Value="#CCCCCC" />
  <Color Key="TabContentBg"  Value="#FFFFFF" />
  <Color Key="TabItemText"   Value="#000000" />
  <Color Key="TabItemSelectedText" Value="#000000" />
  <Color Key="TabItemCloseBtn"     Value="#999999" />
  <Color Key="TabItemCloseBtnHover" Value="#E81123" />

  <!-- ============================================================ -->
  <!-- ScrollBar / ScrollViewer                                      -->
  <!-- ============================================================ -->
  <Color Key="ScrollBarTrack"      Value="#F0F0F0" />
  <Color Key="ScrollBarThumb"      Value="#C1C1C1" />
  <Color Key="ScrollBarThumbHover" Value="#A0A0A0" />

  <!-- ============================================================ -->
  <!-- Menu / MenuBar / MenuItem                                     -->
  <!-- ============================================================ -->
  <Color Key="MenuBarBg"          Value="#F5F5F5" />
  <Color Key="MenuBarHoverBg"     Value="#E5F3FF" />
  <Color Key="MenuBarOpenBg"      Value="#CCE4F7" />
  <Color Key="MenuBarText"        Value="#000000" />
  <Color Key="MenuBg"             Value="#FFFFFF" />
  <Color Key="MenuBorder"         Value="#CCCCCC" />
  <Color Key="MenuItemHoverBg"    Value="#E5F3FF" />
  <Color Key="MenuItemText"       Value="#000000" />
  <Color Key="MenuItemDisabledText" Value="#999999" />
  <Color Key="MenuItemSeparator"  Value="#DDDDDD" />
  <Color Key="MenuItemCheckMark"  Value="#0078D7" />
  <Color Key="MenuItemArrow"      Value="#666666" />

  <!-- ============================================================ -->
  <!-- Toolbar / ToolbarItem                                         -->
  <!-- ============================================================ -->
  <Color Key="ToolbarBg"              Value="#F5F5F5" />
  <Color Key="ToolbarBorder"          Value="#CCCCCC" />
  <Color Key="ToolbarItemHoverBg"     Value="#E5F3FF" />
  <Color Key="ToolbarItemPressedBg"   Value="#CCE4F7" />
  <Color Key="ToolbarItemCheckedBg"   Value="#CCE4F7" />
  <Color Key="ToolbarItemText"        Value="#000000" />
  <Color Key="ToolbarItemDisabledText" Value="#999999" />
  <Color Key="ToolbarSeparatorLine"   Value="#CCCCCC" />

  <!-- ============================================================ -->
  <!-- StatusBar                                                     -->
  <!-- ============================================================ -->
  <Color Key="StatusBarBg"       Value="#F0F0F0" />
  <Color Key="StatusBarBorder"   Value="#CCCCCC" />
  <Color Key="StatusBarGrip"     Value="#999999" />
  <Color Key="StatusBarItemText" Value="#000000" />

  <!-- ============================================================ -->
  <!-- TreeView                                                      -->
  <!-- ============================================================ -->
  <Color Key="TreeViewItemHoverBg"     Value="#E5F3FF" />
  <Color Key="TreeViewItemSelectedBg"  Value="#0078D7" />
  <Color Key="TreeViewItemText"        Value="#000000" />
  <Color Key="TreeViewItemSelectedText" Value="#FFFFFF" />
  <Color Key="TreeViewExpandBtn"       Value="#666666" />

  <!-- ============================================================ -->
  <!-- SideBar                                                       -->
  <!-- ============================================================ -->
  <Color Key="SideBarBg"              Value="#F3F3F3" />
  <Color Key="SideBarBorder"          Value="#E0E0E0" />
  <Color Key="SideBarHeaderBg"        Value="#EBEBEB" />
  <Color Key="SideBarHeaderText"      Value="#000000" />
  <Color Key="SideBarCollapseBtn"     Value="#666666" />
  <Color Key="SideBarCollapseBtnHover" Value="#999999" />

  <!-- ============================================================ -->
  <!-- Splitter                                                      -->
  <!-- ============================================================ -->
  <Color Key="SplitterBg"      Value="#E0E0E0" />
  <Color Key="SplitterHoverBg" Value="#CCE4F7" />
  <Color Key="SplitterActiveBg" Value="#0078D7" />
  <Color Key="SplitterGrip"    Value="#999999" />

</Theme>
