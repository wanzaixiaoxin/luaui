<?xml version="1.0" encoding="UTF-8"?>
<!-- Complex form layout test -->
<StackPanel Orientation="Vertical" Spacing="12" Margin="16">
    <TextBlock Text="Login Form" FontSize="20" FontWeight="Bold"/>
    
    <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Username:" Width="100" VerticalAlignment="Center"/>
        <TextBox Name="UsernameBox" Width="200"/>
    </StackPanel>
    
    <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Password:" Width="100" VerticalAlignment="Center"/>
        <TextBox Name="PasswordBox" Width="200"/>
    </StackPanel>
    
    <StackPanel Orientation="Horizontal" Spacing="8">
        <CheckBox Content="Remember me"/>
    </StackPanel>
    
    <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Login" Width="80"/>
        <Button Content="Cancel" Width="80"/>
    </StackPanel>
</StackPanel>
