<?xml version="1.0" encoding="UTF-8"?>
<!-- Grid Layout Test - Enhanced -->
<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
<StackPanel Orientation="Vertical" Margin="20" Spacing="16">
    
    <!-- Title -->
    <TextBlock Text="{Binding TestTitle}" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
    <TextBlock Text="{Binding TestDescription}" FontSize="13" Foreground="#757575"/>
    
    <!-- Auto Sizing Demo -->
    <Border Background="#E3F2FD" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Auto Sizing Demo" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="Rows/Columns sized to content" FontSize="11" Foreground="#757575"/>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Header Row -->
                <Border Grid.Row="0" Grid.Column="0" Background="#1976D2" Padding="12,8" CornerRadius="4,0,0,0">
                    <TextBlock Text="Name" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Background="#1976D2" Padding="12,8">
                    <TextBlock Text="Age" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Background="#1976D2" Padding="12,8" CornerRadius="0,4,0,0">
                    <TextBlock Text="Description" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                
                <!-- Row 1 -->
                <Border Grid.Row="1" Grid.Column="0" Background="#E3F2FD" Padding="12,8">
                    <TextBlock Text="Alice"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Background="#E3F2FD" Padding="12,8">
                    <TextBlock Text="25"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" Background="#E3F2FD" Padding="12,8">
                    <TextBlock Text="Software Engineer"/>
                </Border>
                
                <!-- Row 2 -->
                <Border Grid.Row="2" Grid.Column="0" Background="#BBDEFB" Padding="12,8" CornerRadius="0,0,0,4">
                    <TextBlock Text="Bob"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="1" Background="#BBDEFB" Padding="12,8">
                    <TextBlock Text="30"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="2" Background="#BBDEFB" Padding="12,8" CornerRadius="0,0,4,0">
                    <TextBlock Text="Product Manager"/>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
    
    <!-- Star Sizing Demo -->
    <Border Background="#E8F5E9" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Star Sizing Demo (Proportional)" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="1*:2*:1* ratio for columns" FontSize="11" Foreground="#757575"/>
            
            <Grid Height="100">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#E53935" CornerRadius="4" Margin="2">
                    <TextBlock Text="1*" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="1" Background="#43A047" CornerRadius="4" Margin="2">
                    <TextBlock Text="2*" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="2" Background="#1E88E5" CornerRadius="4" Margin="2">
                    <TextBlock Text="1*" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
    
    <!-- Pixel + Auto + Star Mix -->
    <Border Background="#FFF3E0" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Mixed Sizing (Pixel + Auto + Star)" FontWeight="SemiBold" FontSize="14"/>
            
            <Grid Height="120">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#E53935" CornerRadius="4" Margin="2">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="80px" Foreground="White" FontSize="11"/>
                        <TextBlock Text="Fixed" Foreground="White" FontSize="10"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#43A047" CornerRadius="4" Margin="2" Padding="20,0">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Auto" Foreground="White" FontSize="11"/>
                        <TextBlock Text="Content" Foreground="White" FontSize="10"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#1E88E5" CornerRadius="4" Margin="2">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="*" Foreground="White" FontSize="11"/>
                        <TextBlock Text="Fill" Foreground="White" FontSize="10"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
    
    <!-- ColumnSpan/RowSpan Demo -->
    <Border Background="#FCE4EC" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="ColumnSpan &amp; RowSpan Demo" FontWeight="SemiBold" FontSize="14"/>
            
            <Grid Height="150">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Header spanning all columns -->
                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="#8E24AA" CornerRadius="4" Margin="2" Padding="8">
                    <TextBlock Text="Header (ColumnSpan=3)" Foreground="White" HorizontalAlignment="Center"/>
                </Border>
                
                <!-- Left cell spanning 2 rows -->
                <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="#E53935" CornerRadius="4" Margin="2">
                    <TextBlock Text="RowSpan=2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                </Border>
                
                <!-- Other cells -->
                <Border Grid.Row="1" Grid.Column="1" Background="#43A047" CornerRadius="4" Margin="2"/>
                <Border Grid.Row="1" Grid.Column="2" Background="#1E88E5" CornerRadius="4" Margin="2"/>
                <Border Grid.Row="2" Grid.Column="1" Background="#FF7043" CornerRadius="4" Margin="2"/>
                <Border Grid.Row="2" Grid.Column="2" Background="#26A69A" CornerRadius="4" Margin="2"/>
            </Grid>
        </StackPanel>
    </Border>
    
    <!-- Nested Grid Demo -->
    <Border Background="#F5F5F5" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Nested Grid Demo" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="Grid inside Grid cell" FontSize="11" Foreground="#757575"/>
            
            <Grid Height="180">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left: Simple content -->
                <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="4" Margin="2">
                    <TextBlock Text="Simple Cell" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1976D2"/>
                </Border>
                
                <!-- Right: Nested Grid -->
                <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="4" Margin="2" Padding="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Row="0" Grid.Column="0" Background="#E53935" CornerRadius="2" Margin="1">
                            <TextBlock Text="A" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Background="#43A047" CornerRadius="2" Margin="1">
                            <TextBlock Text="B" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Background="#1E88E5" CornerRadius="2" Margin="1">
                            <TextBlock Text="C" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Background="#8E24AA" CornerRadius="2" Margin="1">
                            <TextBlock Text="D" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
    
    <!-- Dynamic Column Width Demo -->
    <Border Background="#E8EAF6" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Dynamic Column Width" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="{Binding ColWidthText}" FontSize="12" Foreground="#757575"/>
            
            <Grid Height="80">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Col1Width}"/>
                    <ColumnDefinition Width="{Binding Col2Width}"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#E53935" CornerRadius="4" Margin="2">
                    <TextBlock Text="Col 1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="1" Background="#43A047" CornerRadius="4" Margin="2">
                    <TextBlock Text="Col 2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
    
    <!-- Controls -->
    <Border Background="#FAFAFA" Padding="16" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
        <StackPanel Orientation="Vertical" Spacing="12">
            <TextBlock Text="Controls" FontWeight="SemiBold" FontSize="14"/>
            
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Col 1:" VerticalAlignment="Center" Width="50"/>
                <Slider Value="{Binding Col1Ratio, Mode=TwoWay}" Minimum="0.5" Maximum="3" Width="150"/>
                <TextBlock Text="{Binding Col1RatioText}" VerticalAlignment="Center" Width="50"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Col 2:" VerticalAlignment="Center" Width="50"/>
                <Slider Value="{Binding Col2Ratio, Mode=TwoWay}" Minimum="0.5" Maximum="3" Width="150"/>
                <TextBlock Text="{Binding Col2RatioText}" VerticalAlignment="Center" Width="50"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Equal" Click="EqualCommand"/>
                <Button Content="Reset" Click="ResetCommand" Style="Accent"/>
            </StackPanel>
        </StackPanel>
    </Border>
    
</StackPanel>
</ScrollViewer>
