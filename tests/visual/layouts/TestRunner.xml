<?xml version="1.0" encoding="UTF-8"?>
<!-- LuaUI Visual Test Suite - Test Runner with Real Layout Demos -->
<StackPanel Orientation="Vertical" Margin="0">
    
    <!-- Header -->
    <Border Background="#1976D2" Padding="16,10">
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="LuaUI Visual Test Suite" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="{Binding CurrentTestName}" FontSize="12" Foreground="#BBDEFB" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
    
    <!-- Test Selection Buttons -->
    <Border Background="#F5F5F5" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Spacing="4">
            <Button Content="StackPanel" Click="ShowStackPanel" Width="90" Height="28" FontSize="12"/>
            <Button Content="Grid" Click="ShowGrid" Width="70" Height="28" FontSize="12"/>
            <Button Content="Canvas" Click="ShowCanvas" Width="70" Height="28" FontSize="12"/>
            <Button Content="DockPanel" Click="ShowDockPanel" Width="80" Height="28" FontSize="12"/>
            <Button Content="WrapPanel" Click="ShowWrapPanel" Width="80" Height="28" FontSize="12"/>
            <Button Content="ScrollViewer" Click="ShowScrollViewer" Width="90" Height="28" FontSize="12"/>
            <Button Content="Viewbox" Click="ShowViewbox" Width="70" Height="28" FontSize="12"/>
        </StackPanel>
    </Border>
    
    <!-- Content Area - Shows the actual layout demo -->
    <Border Background="White" Padding="16" MinHeight="400">
        <StackPanel Orientation="Vertical" Spacing="12">
            
            <!-- Test Title -->
            <TextBlock Text="{Binding TestTitle}" FontSize="16" FontWeight="Bold" Foreground="#1976D2"/>
            <TextBlock Text="{Binding TestDescription}" FontSize="11" Foreground="#757575"/>
            
            <!-- Demo Area - Container for all layout demos -->
            <Border Background="#FAFAFA" Padding="12" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1" MinHeight="300">
                <StackPanel Orientation="Vertical">
                    
                    <!-- StackPanel Demo -->
                    <StackPanel Orientation="Vertical" Spacing="8" Visibility="{Binding StackPanelVisible}">
                        <TextBlock Text="Vertical StackPanel (Spacing=8)" FontWeight="SemiBold" FontSize="13"/>
                        <StackPanel Orientation="Vertical" Spacing="8">
                            <Border Background="#E53935" Height="50" CornerRadius="4">
                                <TextBlock Text="Item 1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#43A047" Height="60" CornerRadius="4">
                                <TextBlock Text="Item 2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#1E88E5" Height="40" CornerRadius="4">
                                <TextBlock Text="Item 3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        
                        <TextBlock Text="Horizontal StackPanel" FontWeight="SemiBold" FontSize="13" Margin="0,16,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#E53935" Width="80" Height="50" CornerRadius="4">
                                <TextBlock Text="A" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                            </Border>
                            <Border Background="#43A047" Width="100" Height="50" CornerRadius="4">
                                <TextBlock Text="B" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                            </Border>
                            <Border Background="#1E88E5" Width="60" Height="50" CornerRadius="4">
                                <TextBlock Text="C" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                
                <!-- Grid Demo -->
                <StackPanel Orientation="Vertical" Spacing="8" Visibility="{Binding GridVisible}">
                    <TextBlock Text="Grid Layout Demo" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="(Grid with RowDefinitions/ColumnDefinitions not supported in XML)" FontSize="11" Foreground="#757575"/>
                    <Border Background="#E3F2FD" Padding="16" CornerRadius="4">
                        <StackPanel Orientation="Vertical" Spacing="8">
                            <TextBlock Text="Grid features:" FontWeight="SemiBold"/>
                            <TextBlock Text="• RowDefinitions / ColumnDefinitions"/>
                            <TextBlock Text="• Height/Width: Auto, Pixel, Star"/>
                            <TextBlock Text="• Grid.Row, Grid.Column attached properties"/>
                            <TextBlock Text="• Grid.RowSpan, Grid.ColumnSpan for spanning"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Canvas Demo -->
                <StackPanel Orientation="Vertical" Spacing="8" Visibility="{Binding CanvasVisible}">
                    <TextBlock Text="Absolute Positioning with Canvas.Left/Top" FontWeight="SemiBold" FontSize="13"/>
                    <Border Background="White" Height="250" CornerRadius="4" BorderBrush="#BDBDBD" BorderThickness="1">
                        <Canvas>
                            <Border Canvas.Left="30" Canvas.Top="20" Width="100" Height="60" Background="#E53935" CornerRadius="4">
                                <TextBlock Text="(30,20)" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <Border Canvas.Left="180" Canvas.Top="60" Width="120" Height="80" Background="#43A047" CornerRadius="4">
                                <TextBlock Text="(180,60)" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <Border Canvas.Left="60" Canvas.Top="150" Width="90" Height="70" Background="#1E88E5" CornerRadius="4">
                                <TextBlock Text="(60,150)" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <Border Canvas.Left="200" Canvas.Top="170" Width="80" Height="50" Background="#8E24AA" CornerRadius="4">
                                <TextBlock Text="(200,170)" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                        </Canvas>
                    </Border>
                </StackPanel>
                
                <!-- DockPanel Demo -->
                <StackPanel Orientation="Vertical" Spacing="8" Visibility="{Binding DockPanelVisible}">
                    <TextBlock Text="Dock to Edges (Top, Bottom, Left, Right, Center)" FontWeight="SemiBold" FontSize="13"/>
                    <Border Background="White" Height="220" CornerRadius="4" BorderBrush="#BDBDBD" BorderThickness="1">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Height="40" Background="#E53935" Margin="2" CornerRadius="4">
                                <TextBlock Text="Top Dock" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border DockPanel.Dock="Bottom" Height="40" Background="#43A047" Margin="2" CornerRadius="4">
                                <TextBlock Text="Bottom Dock" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border DockPanel.Dock="Left" Width="80" Background="#1E88E5" Margin="2" CornerRadius="4">
                                <TextBlock Text="Left" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border DockPanel.Dock="Right" Width="80" Background="#8E24AA" Margin="2" CornerRadius="4">
                                <TextBlock Text="Right" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#E3F2FD" Margin="2" CornerRadius="4">
                                <TextBlock Text="Center (LastChildFill)" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1976D2"/>
                            </Border>
                        </DockPanel>
                    </Border>
                </StackPanel>
                
                <!-- WrapPanel Demo -->
                <StackPanel Orientation="Vertical" Spacing="8" Visibility="{Binding WrapPanelVisible}">
                    <TextBlock Text="Auto Wrap when space runs out" FontWeight="SemiBold" FontSize="13"/>
                    <Border Background="White" Height="200" CornerRadius="4" BorderBrush="#BDBDBD" BorderThickness="1">
                        <WrapPanel>
                            <Border Width="70" Height="50" Background="#E53935" Margin="4" CornerRadius="4"/>
                            <Border Width="70" Height="50" Background="#43A047" Margin="4" CornerRadius="4"/>
                            <Border Width="70" Height="50" Background="#1E88E5" Margin="4" CornerRadius="4"/>
                            <Border Width="70" Height="50" Background="#8E24AA" Margin="4" CornerRadius="4"/>
                            <Border Width="70" Height="50" Background="#FF7043" Margin="4" CornerRadius="4"/>
                            <Border Width="70" Height="50" Background="#26A69A" Margin="4" CornerRadius="4"/>
                            <Border Width="70" Height="50" Background="#5C6BC0" Margin="4" CornerRadius="4"/>
                            <Border Width="70" Height="50" Background="#FDD835" Margin="4" CornerRadius="4"/>
                        </WrapPanel>
                    </Border>
                </StackPanel>
                
                <!-- ScrollViewer Demo -->
                <StackPanel Orientation="Vertical" Spacing="8" Visibility="{Binding ScrollViewerVisible}">
                    <TextBlock Text="Scrollable Content (scroll with mouse wheel)" FontWeight="SemiBold" FontSize="13"/>
                    <Border Background="White" CornerRadius="4" BorderBrush="#BDBDBD" BorderThickness="1">
                        <ScrollViewer Width="350" Height="200">
                            <StackPanel Orientation="Vertical" Spacing="8" Margin="8">
                                <Border Height="60" Background="#E53935" CornerRadius="4">
                                    <TextBlock Text="Item 1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Height="60" Background="#43A047" CornerRadius="4">
                                    <TextBlock Text="Item 2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Height="60" Background="#1E88E5" CornerRadius="4">
                                    <TextBlock Text="Item 3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Height="60" Background="#8E24AA" CornerRadius="4">
                                    <TextBlock Text="Item 4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Height="60" Background="#FF7043" CornerRadius="4">
                                    <TextBlock Text="Item 5" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
                
                <!-- Viewbox Demo -->
                <StackPanel Orientation="Vertical" Spacing="8" Visibility="{Binding ViewboxVisible}">
                    <TextBlock Text="Content Scaling (Stretch=Uniform)" FontWeight="SemiBold" FontSize="13"/>
                    <Border Background="White" Height="200" CornerRadius="4" BorderBrush="#BDBDBD" BorderThickness="1">
                        <Viewbox Stretch="Uniform">
                            <Border Width="150" Height="100" Background="#1976D2" CornerRadius="8">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="Viewbox Content" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="150x100 scaled" Foreground="White" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </Viewbox>
                    </Border>
                </StackPanel>
                
            </StackPanel>
            </Border>
        </StackPanel>
    </Border>
    
</StackPanel>
