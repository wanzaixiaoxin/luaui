<?xml version="1.0" encoding="UTF-8"?>
<!-- LuaUI Visual Test Runner - ObservableCollection Incremental Update Demo -->
<StackPanel Orientation="Vertical" Margin="20" Spacing="12">
    
    <!-- Header -->
    <StackPanel Orientation="Vertical" Spacing="4">
        <TextBlock Text="ObservableCollection Demo" FontSize="24" FontWeight="Bold" Foreground="#1976D2"/>
        <TextBlock Text="{Binding TestCountText}" FontSize="12" Foreground="#757575"/>
        <TextBlock Text="Features: Incremental Add/Remove/Clear with automatic UI updates" 
                   FontSize="10" Foreground="#999999" FontStyle="Italic"/>
    </StackPanel>
    
    <!-- Test List -->
    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Padding="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Test List (ObservableCollection):" FontWeight="SemiBold" FontSize="13"/>
            <ListBox ItemsSource="{Binding Tests}" Height="200"/>
        </StackPanel>
    </Border>
    
    <!-- Incremental Update Controls -->
    <Border Background="#F5F5F5" Padding="12" CornerRadius="4">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Incremental Update Demo" FontWeight="SemiBold" FontSize="14" Foreground="#1565C0"/>
            
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Add Single" Command="{Binding AddTestCommand}" Style="Primary"/>
                <Button Content="Add 5 Items" Command="{Binding AddMultipleTestsCommand}" Style="Primary"/>
                <Button Content="Remove Last" Command="{Binding RemoveLastTestCommand}" Style="Secondary"/>
                <Button Content="Clear All" Command="{Binding ClearTestsCommand}" Style="Secondary"/>
            </StackPanel>
        </StackPanel>
    </Border>
    
    <!-- Status -->
    <Border Background="#FAFAFA" Padding="8" CornerRadius="2">
        <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#757575"/>
    </Border>
    
</StackPanel>
