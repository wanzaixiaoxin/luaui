<?xml version="1.0" encoding="UTF-8"?>
<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
<!-- DockPanel Layout Test - Enhanced -->
<StackPanel Orientation="Vertical" Margin="20" Spacing="16">
    
    <!-- Title -->
    <TextBlock Text="{Binding TestTitle}" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
    <TextBlock Text="{Binding TestDescription}" FontSize="13" Foreground="#757575"/>
    
    <!-- Standard Dock Demo -->
    <Border Background="#E3F2FD" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Standard Four-Side Dock" FontWeight="SemiBold" FontSize="14"/>
            
            <Border Background="White" Height="200" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel LastChildFill="true">
                    <Border DockPanel.Dock="Top" Height="40" Background="#E53935" CornerRadius="4">
                        <TextBlock Text="Top" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Height="40" Background="#43A047" CornerRadius="4">
                        <TextBlock Text="Bottom" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border DockPanel.Dock="Left" Width="80" Background="#1E88E5" CornerRadius="4">
                        <TextBlock Text="Left" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border DockPanel.Dock="Right" Width="80" Background="#8E24AA" CornerRadius="4">
                        <TextBlock Text="Right" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#E8F5E9" CornerRadius="4">
                        <TextBlock Text="Center (Fill)" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#43A047"/>
                    </Border>
                </DockPanel>
            </Border>
        </StackPanel>
    </Border>
    
    <!-- Multiple Same Direction Demo -->
    <Border Background="#E8F5E9" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Multiple Same Direction (Top x3)" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="Each Top dock takes remaining width from top" FontSize="11" Foreground="#757575"/>
            
            <Border Background="White" Height="200" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel LastChildFill="true">
                    <Border DockPanel.Dock="Top" Height="30" Background="#E53935" CornerRadius="4">
                        <TextBlock Text="Top 1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                    </Border>
                    <Border DockPanel.Dock="Top" Height="30" Background="#FF7043" CornerRadius="4">
                        <TextBlock Text="Top 2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                    </Border>
                    <Border DockPanel.Dock="Top" Height="30" Background="#FFA726" CornerRadius="4">
                        <TextBlock Text="Top 3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                    </Border>
                    <Border DockPanel.Dock="Left" Width="80" Background="#1E88E5" CornerRadius="4">
                        <TextBlock Text="Left" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#F5F5F5" CornerRadius="4">
                        <TextBlock Text="Fill Area" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#757575"/>
                    </Border>
                </DockPanel>
            </Border>
        </StackPanel>
    </Border>
    
    <!-- Dock Order Demo -->
    <Border Background="#FFF3E0" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Dock Order Matters" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="Order: Right -> Left -> Bottom -> Top (different from standard)" FontSize="11" Foreground="#757575"/>
            
            <Border Background="White" Height="200" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel LastChildFill="true">
                    <Border DockPanel.Dock="Right" Width="80" Background="#8E24AA" CornerRadius="4">
                        <TextBlock Text="Right (1st)" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border DockPanel.Dock="Left" Width="80" Background="#1E88E5" CornerRadius="4">
                        <TextBlock Text="Left (2nd)" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Height="40" Background="#43A047" CornerRadius="4">
                        <TextBlock Text="Bottom (3rd)" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border DockPanel.Dock="Top" Height="40" Background="#E53935" CornerRadius="4">
                        <TextBlock Text="Top (4th)" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border Background="#FFF8E1" CornerRadius="4">
                        <TextBlock Text="Fill" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#757575"/>
                    </Border>
                </DockPanel>
            </Border>
        </StackPanel>
    </Border>
    
    <!-- LastChildFill Toggle Demo -->
    <Border Background="#FCE4EC" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="LastChildFill Toggle" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="{Binding LastChildFillText}" FontSize="12" Foreground="#757575"/>
            
            <Border Background="White" Height="180" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel LastChildFill="{Binding LastChildFill}">
                    <Border DockPanel.Dock="Top" Height="35" Background="#E53935" CornerRadius="4">
                        <TextBlock Text="Top" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Height="35" Background="#43A047" CornerRadius="4">
                        <TextBlock Text="Bottom" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border DockPanel.Dock="Left" Width="70" Background="#1E88E5" CornerRadius="4">
                        <TextBlock Text="Left" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border DockPanel.Dock="Right" Width="70" Background="#8E24AA" CornerRadius="4">
                        <TextBlock Text="Right" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#FCE4EC" CornerRadius="4" BorderBrush="#E91E63" BorderThickness="2">
                        <TextBlock Text="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E91E63"/>
                    </Border>
                </DockPanel>
            </Border>
        </StackPanel>
    </Border>
    
    <!-- Controls -->
    <Border Background="#FAFAFA" Padding="16" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
        <StackPanel Orientation="Vertical" Spacing="12">
            <TextBlock Text="Controls" FontWeight="SemiBold" FontSize="14"/>
            
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="LastChildFill:" VerticalAlignment="Center"/>
                <CheckBox IsChecked="{Binding LastChildFill, Mode=TwoWay}"/>
            </StackPanel>
        </StackPanel>
    </Border>
    
</StackPanel>
</ScrollViewer>
