<?xml version="1.0" encoding="UTF-8"?>
<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
<!-- StackPanel Layout Test -->
<StackPanel Orientation="Vertical" Margin="20" Spacing="16">
    
    <!-- Title -->
    <TextBlock Text="{Binding TestTitle}" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
    <TextBlock Text="{Binding TestDescription}" FontSize="13" Foreground="#757575"/>
    
    <!-- Vertical StackPanel Demo -->
    <Border Background="#F5F5F5" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Vertical StackPanel (Spacing=8)" FontWeight="SemiBold" FontSize="14"/>
            
            <StackPanel Orientation="Vertical" Spacing="{Binding VerticalSpacing}">
                <Border Background="#FF5733" Height="50" CornerRadius="4">
                    <TextBlock Text="{Binding Item1Text}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#33FF57" Height="60" CornerRadius="4">
                    <TextBlock Text="{Binding Item2Text}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#3357FF" Height="40" CornerRadius="4">
                    <TextBlock Text="{Binding Item3Text}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
            
            <!-- Spacing Control -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <TextBlock Text="Spacing:" VerticalAlignment="Center"/>
                <Slider Value="{Binding VerticalSpacing, Mode=TwoWay}" Minimum="0" Maximum="30" Width="150"/>
                <TextBlock Text="{Binding VerticalSpacingText}" VerticalAlignment="Center" Width="40"/>
            </StackPanel>
        </StackPanel>
    </Border>
    
    <!-- Horizontal StackPanel Demo -->
    <Border Background="#F5F5F5" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Horizontal StackPanel (Spacing=5)" FontWeight="SemiBold" FontSize="14"/>
            
            <StackPanel Orientation="Horizontal" Spacing="{Binding HorizontalSpacing}">
                <Border Background="#FF5733" Width="100" Height="50" CornerRadius="4">
                    <TextBlock Text="100x50" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#33FF57" Width="80" Height="60" CornerRadius="4">
                    <TextBlock Text="80x60" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#3357FF" Width="120" Height="50" CornerRadius="4">
                    <TextBlock Text="120x50" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
            
            <!-- Spacing Control -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <TextBlock Text="Spacing:" VerticalAlignment="Center"/>
                <Slider Value="{Binding HorizontalSpacing, Mode=TwoWay}" Minimum="0" Maximum="30" Width="150"/>
                <TextBlock Text="{Binding HorizontalSpacingText}" VerticalAlignment="Center" Width="40"/>
            </StackPanel>
        </StackPanel>
    </Border>
    
    <!-- Dynamic Orientation Demo -->
    <Border Background="#F5F5F5" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Dynamic Orientation (Bound to ViewModel)" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="{Binding OrientationText}" FontSize="12" Foreground="#757575"/>
            
            <StackPanel Orientation="{Binding Orientation}" Spacing="10" Height="150">
                <Border Background="#FF5733" Width="80" Height="50" CornerRadius="4">
                    <TextBlock Text="Item 1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#33FF57" Width="80" Height="50" CornerRadius="4">
                    <TextBlock Text="Item 2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#3357FF" Width="80" Height="50" CornerRadius="4">
                    <TextBlock Text="Item 3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </StackPanel>
    </Border>
    
    <!-- Visibility Test -->
    <Border Background="#F5F5F5" Padding="16" CornerRadius="8">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Visibility Test" FontWeight="SemiBold" FontSize="14"/>
            
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Background="#FF5733" Width="60" Height="40" CornerRadius="4">
                    <TextBlock Text="Visible" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#33FF57" Width="60" Height="40" CornerRadius="4" IsVisible="{Binding MiddleItemVisible}">
                    <TextBlock Text="Hidden" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#3357FF" Width="60" Height="40" CornerRadius="4">
                    <TextBlock Text="Visible" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
            
            <Button Content="Toggle Middle Item" Click="ToggleVisibilityCommand"/>
        </StackPanel>
    </Border>
    
    <!-- Controls -->
    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
        <Button Content="Add Item" Click="AddItemCommand" Style="Primary"/>
        <Button Content="Remove Item" Click="RemoveItemCommand" Style="Danger"/>
        <Button Content="Toggle Orientation" Click="ToggleOrientationCommand" Style="Accent"/>
        <Button Content="Clear All" Click="ClearAllCommand" Style="Danger"/>
    </StackPanel>
    
    <!-- Dynamic Items -->
    <Border Background="#FAFAFA" Padding="16" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,20">
        <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock Text="Dynamic Items (ViewModel Demo)" FontWeight="SemiBold" FontSize="14"/>
            <StackPanel Orientation="Vertical" Spacing="4">
                <Border Background="#FF5733" Height="40" CornerRadius="4">
                    <TextBlock Text="Dynamic Item 1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#33FF57" Height="40" CornerRadius="4">
                    <TextBlock Text="Dynamic Item 2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Background="#3357FF" Height="40" CornerRadius="4">
                    <TextBlock Text="Dynamic Item 3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </StackPanel>
    </Border>
    
</StackPanel>
</ScrollViewer>
